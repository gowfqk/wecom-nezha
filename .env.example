# 认证密钥
SENDKEY=set_a_sendkey

# 企业微信配置
WECOM_CID=your_corp_id
WECOM_SECRET=your_secret
WECOM_AID=your_agent_id
WECOM_TOUID=@all

# 企业微信回调（可选）
WECOM_TOKEN=your_callback_token
WECOM_ENCODING_AES_KEY=your_aes_key

# 哪吒监控配置
NEZHA_URL=https://nezha.example.com
NEZHA_USERNAME=admin
NEZHA_PASSWORD=your_password

# 缓存配置
CACHE_TYPE=memory
REDIS_STAT=OFF
REDIS_ADDR=localhost:6379
REDIS_PASSWORD=

# 邮件底部链接（可选）
MAIL_FOOTER_URL=

# Telegram Bot 配置（可选）
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_WEBHOOK_SECRET=your_webhook_secret
TELEGRAM_ALLOWED_USERS=123456789,987654321
# Telegram API 地址（使用反向代理时设置）
TELEGRAM_API_BASE=https://api.telegram.org
